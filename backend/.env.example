# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME="Voice Agent Interview Platform"
DEBUG=false

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | groq | google
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
GOOGLE_API_KEY=AIza...

# ── Vector Store (ChromaDB) ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=interview_docs

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/voice_agent

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── GitHub (Personal Access Token — optional but strongly recommended) ───────
# Without token: 60 unauthenticated requests/hr
# With token:    5000 requests/hr
GITHUB_TOKEN=ghp_...

# ── Proxy / IP Rotation (requests-ip-rotator via AWS API Gateway) ────────────
# Set USE_PROXY_ROTATION=true only if you have AWS credentials configured.
USE_PROXY_ROTATION=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
